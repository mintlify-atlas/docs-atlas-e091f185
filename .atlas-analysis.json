  "projectType": "sdk-library",
  "projectName": "KMP-NativeCoroutines",
  "projectDescription": "A Kotlin Multiplatform library that enables Kotlin Coroutines (suspend functions and Flows) to be used natively from Swift with full cancellation support, via Swift Concurrency, Combine, and RxSwift.",

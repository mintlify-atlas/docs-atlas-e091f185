  "keyFeatures": [
    "Full cancellation support for Kotlin suspend functions called from Swift",
    "Generic Flow type preservation across the Kotlin/Swift boundary",
    "Swift Concurrency (async/await) integration via KMPNativeCoroutinesAsync",
    "Combine framework integration via KMPNativeCoroutinesRxSwift",
    "RxSwift integration via KMPNativeCoroutinesRxSwift",
    "KSP-based code generation with @NativeCoroutines annotations",
    "Gradle plugin for automatic native wrapper generation",
    "IDE plugin for IntelliJ/Android Studio with annotation validation",
    "Swift export compatibility mode",
    "Custom CoroutineScope support via @NativeCoroutineScope"
  ],
  "publicApiSurface": [
    "@NativeCoroutines annotation",
    "@NativeCoroutinesState annotation",
    "@NativeCoroutinesIgnore annotation",
    "@NativeCoroutinesRefined annotation",
    "@NativeCoroutinesRefinedState annotation",
    "@NativeCoroutineScope annotation",
    "asyncFunction(for:) — Swift Concurrency async wrapper",
    "asyncResult(for:) — Swift Concurrency result wrapper",
    "asyncError(for:) — Swift Concurrency error wrapper",
    "asyncSequence(for:) — AsyncSequence wrapper for Flows",
    "createPublisher(for:) — Combine AnyPublisher for Flows",
    "createFuture(for:) — Combine Future for suspend functions",
    "createObservable(for:) — RxSwift Observable for Flows",
    "createSingle(for:) — RxSwift Single for suspend functions",
    "NativeFlow type alias",
    "NativeSuspend type alias",
    "NativeCancellable type alias",
    "KmpNativeCoroutinesExtension (Gradle DSL)",
